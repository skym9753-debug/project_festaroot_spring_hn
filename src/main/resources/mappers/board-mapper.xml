<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="Board">

    <!--
        게시글 등록 SQL

        insertPost는 CommunityPostDTO를 받아서 community_post 테이블에 게시글을 저장합니다.

        핵심 흐름:
        1. selectKey로 게시글 번호(post_id)를 먼저 생성
        2. 생성된 post_id가 DTO의 post_id 필드에 들어감
        3. 그 post_id를 사용해서 insert 실행

        order="BEFORE"
        - insert 실행 전에 selectKey를 먼저 실행한다는 의미입니다.

        seq_community_post.nextval
        - Oracle sequence에서 다음 번호를 가져옵니다.
    -->
    <insert id="insertPost">
        <selectKey keyProperty="post_id" resultType="Long" order="BEFORE">
            select seq_community_post.nextval from dual
        </selectKey>

        insert into community_post (
            post_id,
            member_id,
            category,
            title,
            content,
            view_count,
            like_count,
            report_count,
            created_at,
            updated_at
        ) values (
            #{post_id},
            #{member_id},
            #{category},
            #{title},
            #{content},
            0,
            0,
            0,
            sysdate,
            sysdate
        )
    </insert>


    <!--
        게시글 총 개수 조회 SQL

        게시판 목록에서 페이지네이션을 만들려면 전체 게시글 수가 필요합니다.

        예:
        - 전체 게시글 53개
        - 한 페이지에 10개씩 표시
        - 총 페이지 수 = 6페이지

        이 SQL은 단순히 전체 개수만 세는 것이 아니라,
        현재 선택된 카테고리와 검색 조건을 반영한 개수를 조회합니다.

        예:
        /board/posts?category=free&searchType=title&keyword=축제

        위 요청이면:
        - 자유게시판 글 중에서
        - 제목에 '축제'가 들어간 게시글 개수만 조회합니다.
    -->
    <select id="selectCount" resultType="int">
        select count(*)
        from community_post cp

        <!--
            작성자로 검색할 때만 member 테이블을 join합니다.

            이유:
            - 제목 검색: community_post.title만 필요
            - 내용 검색: community_post.content만 필요
            - 작성자 검색: member.nickname이 필요

            따라서 작성자 검색일 때만 member 테이블을 연결합니다.
        -->
        <if test="searchType == 'author'">
            left join member m
            on cp.member_id = m.member_id
        </if>

        <!--
            <where> 태그는 MyBatis가 WHERE 키워드를 자동으로 붙여줍니다.

            장점:
            - 조건이 하나도 없으면 WHERE가 생기지 않음
            - 조건 앞에 and가 있어도 자동으로 정리해 줌

            예:
            and cp.category = #{category}

            실제 SQL에서는:
            where cp.category = ?
        -->
        <where>

            <!--
                카테고리 필터 조건

                category가 all이면 전체게시판이므로 조건을 걸지 않습니다.
                category가 free/review/tip/notice이면 해당 카테고리만 조회합니다.
            -->
            <if test="category != null and category != 'all'">
                and cp.category = #{category}
            </if>

            <!--
                검색어가 있을 때만 검색 조건을 추가합니다.

                keyword가 null이거나 빈 문자열이면 검색 조건 없이 조회합니다.
            -->
            <if test="keyword != null and keyword != ''">

                <!--
                    searchType 값에 따라 검색 대상 컬럼을 다르게 설정합니다.

                    title   → 제목 검색
                    content → 내용 검색
                    author  → 작성자 닉네임 검색
                -->
                <choose>
                    <when test="searchType == 'title'">
                        and cp.title like '%' || #{keyword} || '%'
                    </when>

                    <when test="searchType == 'content'">
                        and cp.content like '%' || #{keyword} || '%'
                    </when>

                    <when test="searchType == 'author'">
                        and m.nickname like '%' || #{keyword} || '%'
                    </when>
                </choose>

            </if>
        </where>
    </select>


    <!--
        게시글 목록 조회 SQL

        이 SQL은 게시판 목록 화면에서 실제 게시글 리스트를 가져옵니다.

        지원하는 기능:
        1. 카테고리별 조회
        2. 제목/내용/작성자 검색
        3. 최신순/조회순/좋아요순 정렬
        4. 페이지네이션

        프론트에서 넘어오는 값 예시:
        - cpage = 1
        - category = free
        - sortBy = views
        - searchType = title
        - keyword = 축제
        - startNum = 1
        - endNum = 10
    -->
    <select id="selectList" resultType="com.study.app.domains.board.dto.CommunityPostDTO">

        <!--
            바깥 select

            안쪽에서 row_number()로 번호를 붙인 뒤,
            find_num이 startNum ~ endNum 사이인 데이터만 가져옵니다.

            즉, Oracle에서 페이지네이션을 구현하는 방식입니다.
        -->
        select *
        from (

            <!--
                실제 게시글 데이터를 조회하는 내부 select
            -->
            select
                cp.post_id,
                cp.member_id,
                cp.category,
                cp.title,
                cp.content,
                cp.view_count,
                cp.like_count,
                cp.report_count,
                cp.created_at,
                m.nickname,

                <!--
                    row_number()는 조회된 결과에 1번부터 순번을 붙입니다.

                    예:
                    최신순 정렬 결과가 100개라면
                    1, 2, 3, 4 ... 100번까지 번호가 붙습니다.

                    그 후 바깥 쿼리에서
                    find_num between 1 and 10
                    처럼 잘라서 페이지를 만듭니다.
                -->
                row_number() over (
                    order by

                    <!--
                        정렬 조건

                        sortBy 값에 따라 ORDER BY 기준을 바꿉니다.

                        views  → 조회수 높은 순
                        likes  → 좋아요 많은 순
                        latest → 최신순

                        latest는 따로 when을 만들지 않고 otherwise로 처리했습니다.
                    -->
                    <choose>
                        <when test="sortBy == 'views'">
                            cp.view_count desc
                        </when>

                        <when test="sortBy == 'likes'">
                            cp.like_count desc
                        </when>

                        <otherwise>
                            cp.post_id desc
                        </otherwise>
                    </choose>
                ) as find_num

            from community_post cp

            <!--
                게시글 작성자의 닉네임을 가져오기 위해 member 테이블과 조인합니다.

                cp.member_id = m.member_id

                community_post에는 member_id만 저장되어 있고,
                화면에는 nickname을 보여줘야 하므로 join이 필요합니다.
            -->
            left join member m
            on cp.member_id = m.member_id

            <!--
                카테고리, 검색 조건을 동적으로 붙이는 영역
            -->
            <where>

                <!--
                    카테고리별 조회 조건

                    전체게시판(all)이면 조건 없음.
                    자유게시판(free), 후기(review), 꿀팁(tip), 공지(notice)이면 해당 값만 조회.
                -->
                <if test="category != null and category != 'all'">
                    and cp.category = #{category}
                </if>

                <!--
                    검색어가 있을 때만 검색 조건 추가
                -->
                <if test="keyword != null and keyword != ''">

                    <!--
                        검색 타입별 검색 컬럼 분기
                    -->
                    <choose>
                        <when test="searchType == 'title'">
                            and cp.title like '%' || #{keyword} || '%'
                        </when>

                        <when test="searchType == 'content'">
                            and cp.content like '%' || #{keyword} || '%'
                        </when>

                        <when test="searchType == 'author'">
                            and m.nickname like '%' || #{keyword} || '%'
                        </when>
                    </choose>

                </if>
            </where>
        )

        <!--
            페이지네이션 조건

            Controller에서 계산한 startNum, endNum을 사용합니다.

            예:
            cpage = 1 → startNum = 1, endNum = 10
            cpage = 2 → startNum = 11, endNum = 20
            cpage = 3 → startNum = 21, endNum = 30
        -->
        where find_num between #{startNum} and #{endNum}

    </select>


    <!--
        게시글 상세 조회 SQL

        게시글 번호(post_id) 하나를 기준으로 게시글 상세 정보를 조회합니다.

        상세 페이지에서 필요한 정보:
        - 게시글 번호
        - 작성자 ID
        - 카테고리
        - 제목
        - 내용
        - 좋아요 수
        - 조회수
        - 작성일
        - 작성자 닉네임
    -->
    <select id="selectById" resultType="com.study.app.domains.board.dto.CommunityPostDTO">
        select
            cp.post_id,
            cp.member_id,
            cp.category,
            cp.title,
            cp.content,
            cp.like_count,
            cp.view_count,
            cp.created_at,
            m.nickname,
            m.profile_image_url
        from community_post cp
        left join member m
        on cp.member_id = m.member_id
        where cp.post_id = #{id}
    </select>


    <!--
        게시글 수정 SQL

        post_id가 일치하는 게시글의 제목과 내용을 수정합니다.

        주의:
        현재 SQL은 작성자 검증을 하지 않습니다.

        즉, 백엔드 Service나 Controller에서
        "현재 로그인한 사용자와 게시글 작성자가 같은지"
        먼저 확인하는 것이 좋습니다.
    -->
    <update id="updatePostById">
        update community_post
        set
            title = #{title},
            content = #{content},
            updated_at = sysdate
        where post_id = #{post_id}
    </update>


    <!--
        게시글 삭제 SQL

        post_id가 일치하는 게시글을 삭제합니다.

        주의:
        댓글, 첨부파일, 좋아요, 신고 테이블이 post_id를 참조하고 있다면
        먼저 자식 데이터를 삭제하거나
        DB에 ON DELETE CASCADE 설정이 필요할 수 있습니다.
    -->
    <delete id="deletePostById">
        delete from community_post
        where post_id = #{id}
    </delete>


    <!--
        조회수 증가 SQL

        상세 페이지에 들어갈 때 조회수를 1 증가시키는 용도입니다.

        NVL(view_count, 0)
        - view_count가 null이면 0으로 취급합니다.

        즉:
        null + 1이 아니라
        0 + 1이 되도록 처리합니다.
    -->
    <update id="increaseViewCount">
        update community_post
        set view_count = NVL(view_count, 0) + 1
        where post_id = #{post_id}
    </update>


    <!--
        신고 수 증가 SQL

        게시글 신고가 접수되었을 때 report_count를 1 증가시킵니다.

        NVL(report_count, 0)
        - report_count가 null이면 0으로 보고 계산합니다.
    -->
    <update id="increaseReportCount">
        update community_post
        set report_count = NVL(report_count, 0) + 1
        where post_id = #{post_id}
    </update>
    
    
    <select id="getMyPostCount" resultType="int">
    		select count(*) from community_post where member_id = #{memberId}
    </select>
	
	<select id="getMypostList" resultType="com.study.app.domains.board.dto.CommunityPostDTO">
		select * from community_post where member_id = #{memberId} order by post_id desc
	</select>
</mapper>