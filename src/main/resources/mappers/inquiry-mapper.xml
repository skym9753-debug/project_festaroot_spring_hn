<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.study.app.domains.inquiry.InquiryDAO">

    <!-- 문의글 본문 저장 -->
    <insert id="insertInquiry" parameterType="com.study.app.domains.inquiry.dto.InquiryDTO">
        <selectKey keyProperty="inquiry_id" resultType="long" order="BEFORE">
            SELECT User_inquiry_seq.nextval FROM dual
        </selectKey>
        INSERT INTO User_inquiry (
            inquiry_id,
            member_id,
            category,
            title,
            content,
            status,
            created_at
        ) VALUES (
            #{inquiry_id},
            #{member_id},
            #{category},
            #{title},
            #{content},
            'PENDING',
            SYSDATE
        )
    </insert>

    <!-- 첨부파일 리스트 일괄 저장 -->
    <insert id="insertAttachments" parameterType="java.util.List">
        INSERT INTO Inquiry_attachment (
            attach_id,
            inquiry_id,
            file_name,
            file_path,
            file_size,
            file_type,
            created_at
        )
        SELECT Inquiry_attachment_seq.nextval, A.* FROM (
            <foreach collection="list" item="item" separator="UNION ALL">
                SELECT 
                    #{item.inquiry_id}, 
                    #{item.file_name}, 
                    #{item.file_path}, 
                    #{item.file_size}, 
                    #{item.file_type}, 
                    SYSDATE 
                FROM dual
            </foreach>
        ) A
    </insert>
	
	<select id="getMyInquiryList" resultType="com.study.app.domains.inquiry.dto.InquiryDTO">
		SELECT * FROM USER_INQUIRY WHERE MEMBER_ID = #{MEMBER_ID} ORDER BY INQUIRY_ID DESC
	</select>
	
	<select id="inquiryDetail" resultType="com.study.app.domains.inquiry.dto.InquiryDTO">
		SELECT * FROM USER_INQUIRY WHERE INQUIRY_ID = #{INQUIRY_ID}
	</select>

    <!-- 문의글 단건 조회 (추가) -->
    <select id="selectInquiryById" parameterType="long" resultType="com.study.app.domains.inquiry.dto.InquiryDTO">
        SELECT * FROM User_inquiry WHERE inquiry_id = #{inquiry_id}
    </select>

    <!-- 특정 문의의 첨부파일 리스트 조회 -->
    <select id="selectAttachmentsByInquiryId" parameterType="long" resultType="com.study.app.domains.inquiry.dto.InquiryAttachmentDTO">
        SELECT * FROM Inquiry_attachment WHERE inquiry_id = #{inquiry_id}
    </select>

    <!-- 개별 첨부파일 조회 -->
    <select id="selectAttachmentById" parameterType="long" resultType="com.study.app.domains.inquiry.dto.InquiryAttachmentDTO">
        SELECT * FROM Inquiry_attachment WHERE attach_id = #{attach_id}
    </select>

    <!-- 개별 첨부파일 삭제 -->
    <delete id="deleteAttachmentById" parameterType="long">
        DELETE FROM Inquiry_attachment WHERE attach_id = #{attach_id}
    </delete>

    <!-- 첨부파일 DB 정보 삭제 -->
    <delete id="deleteAttachmentsByInquiryId" parameterType="long">
        DELETE FROM Inquiry_attachment WHERE inquiry_id = #{inquiry_id}
    </delete>

    <!-- 문의 본문 삭제 -->
    <delete id="deleteInquiry" parameterType="long">
        DELETE FROM User_inquiry WHERE inquiry_id = #{inquiry_id}
    </delete>

    <!-- 문의글 수정 -->
    <update id="updateInquiry" parameterType="com.study.app.domains.inquiry.dto.InquiryDTO">
        UPDATE User_inquiry
        SET category = #{category},
            title = #{title},
            content = #{content}
        WHERE inquiry_id = #{inquiry_id}
    </update>
    
    <select id="getInquiryList" resultType="com.study.app.domains.inquiry.dto.InquiryDTO">
    		select * from user_inquiry order by inquiry_id desc
    </select>

    

    <!-- [관리자] 문의 상태 업데이트 -->
    <update id="updateInquiryStatus">
        UPDATE User_inquiry
        SET status = #{status}
        WHERE inquiry_id = #{inquiry_id}
    </update>
</mapper>
