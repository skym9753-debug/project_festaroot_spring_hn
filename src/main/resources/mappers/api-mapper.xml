<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
<mapper namespace="Api">

    <select id="selectActiveTerms"
            resultType="com.study.app.domains.api.TermsDTO">
        SELECT
            terms_id,
            terms_type,
            title,
            content,
            version,
            required_yn,
            is_active,
            created_at
        FROM terms
        WHERE is_active = 'Y'
        ORDER BY terms_id
    </select>
    


</mapper>