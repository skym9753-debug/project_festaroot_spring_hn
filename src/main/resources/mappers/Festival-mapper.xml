<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  <mapper namespace="Festival">
  
  	<select id="getAll" resultType="com.study.app.dto.FestivalDTO">
  		select * from festival_info
  	</select>
  	<select id="selectByContentId" resultType="com.study.app.dto.FestivalDTO">
  		select * from festival_info where content_id = ${content_id}
  	</select>
  </mapper>